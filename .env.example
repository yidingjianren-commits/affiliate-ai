# AI Affiliate - 环境变量配置
# 复制此文件为 .env 并填写

# 免费AI模型（至少填写一个）
GEMINI_API_KEY=your_gemini_key_here        # Google AI Studio, 免费
DEEPSEEK_API_KEY=your_deepseek_key_here    # DeepSeek, 极低价

# Reddit API（可选，用于 PromoAgent 集成）
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USERNAME=your_username
REDDIT_PASSWORD=your_password
